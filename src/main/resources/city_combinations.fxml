<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="uniza.fri.majba.dis1.CityCombinationController"
      styleClass="dialog-root"
      prefWidth="700"
      prefHeight="600"
      spacing="0">

    <!-- Header -->
    <HBox styleClass="dialog-header" alignment="CENTER_LEFT" spacing="12">
        <padding>
            <Insets top="20" right="24" bottom="20" left="24"/>
        </padding>
        <FontIcon iconLiteral="fa-cogs" iconSize="24" styleClass="dialog-icon"/>
        <VBox spacing="2">
            <Label text="Konfigurácia kombinácií miest" styleClass="dialog-title"/>
            <Label text="Pridávajte, upravujte a odstraňujte kombinácie miest pre simuláciu" styleClass="dialog-subtitle"/>
        </VBox>
    </HBox>

    <Separator styleClass="dialog-separator"/>

    <!-- Content -->
    <VBox spacing="20" VBox.vgrow="ALWAYS" styleClass="dialog-content">
        <padding>
            <Insets top="24" right="24" bottom="24" left="24"/>
        </padding>

        <!-- Drag and Drop section -->
        <VBox spacing="16" styleClass="input-section">
            <Label text="Vytvoriť novú kombináciu" styleClass="section-label">
                <graphic>
                    <FontIcon iconLiteral="fa-hand-pointer-o" iconSize="14"/>
                </graphic>
            </Label>

            <!-- Available cities to drag -->
            <VBox spacing="8">
                <Label text="Dostupné mestá (pretiahnite do zóny nižšie):" styleClass="subsection-label">
                    <graphic>
                        <FontIcon iconLiteral="fa-map-marker" iconSize="12"/>
                    </graphic>
                </Label>
                <FlowPane fx:id="availableCitiesPane"
                         styleClass="cities-container"
                         hgap="8"
                         vgap="8"
                         alignment="CENTER_LEFT"/>
            </VBox>

            <!-- Drop zone -->
            <VBox spacing="8">
                <Label text="Vaša kombinácia:" styleClass="subsection-label">
                    <graphic>
                        <FontIcon iconLiteral="fa-list-ol" iconSize="12"/>
                    </graphic>
                </Label>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Žilina" styleClass="city-chip static-city"/>
                    <Label text="→" styleClass="arrow-label"/>
                    <FlowPane fx:id="dropZonePane"
                             styleClass="drop-zone-inline"
                             hgap="8"
                             vgap="8"
                             alignment="CENTER_LEFT"
                             minHeight="40"
                             HBox.hgrow="ALWAYS"/>
                    <Label text="→" styleClass="arrow-label"/>
                    <Label text="Žilina" styleClass="city-chip static-city"/>
                </HBox>
            </VBox>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="clearButton"
                       text="Vymazať"
                       styleClass="btn btn-secondary"
                       onAction="#onClearDropZone">
                    <graphic>
                        <FontIcon iconLiteral="fa-eraser" iconSize="12"/>
                    </graphic>
                </Button>

                <Button fx:id="addButton"
                       text="Pridať kombináciu"
                       styleClass="btn btn-primary"
                       onAction="#onAddCombination"
                       prefWidth="150">
                    <graphic>
                        <FontIcon iconLiteral="fa-plus" iconSize="12"/>
                    </graphic>
                </Button>
            </HBox>

            <!-- Status label -->
            <Label fx:id="statusLabel"
                   text=""
                   styleClass="status-label"
                   wrapText="true"/>
        </VBox>

        <!-- Help text -->
        <VBox spacing="6" styleClass="help-section">
            <HBox spacing="6" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="fa-info-circle" iconSize="12" styleClass="help-icon"/>
                <Label text="Ako na to:" styleClass="help-label"/>
            </HBox>
            <Label text="1. Kliknite na mestá pre ich výber (zafarbí sa)" styleClass="help-text"/>
            <Label text="2. Vybraté mestá sa zobrazia v 'Vybratá kombinácia'" styleClass="help-text"/>
            <Label text="3. Kliknite na mesto v kombinácii alebo na vybraté mesto pre odstránenie" styleClass="help-text"/>
            <Label text="4. Stlačte 'Pridať kombináciu' pre uloženie" styleClass="help-text"/>
        </VBox>

        <!-- Existing combinations table -->
        <VBox spacing="12" VBox.vgrow="ALWAYS">
            <Label text="Existujúce kombinácie" styleClass="section-label">
                <graphic>
                    <FontIcon iconLiteral="fa-list" iconSize="14"/>
                </graphic>
            </Label>

            <TableView fx:id="combinationsTable"
                      styleClass="combinations-table"
                      VBox.vgrow="ALWAYS"
                      minHeight="200"
                      prefHeight="300">
                <columns>
                    <TableColumn text="KOMBINÁCIA MIEST"
                               fx:id="colCities"
                               prefWidth="500"
                               sortable="false"/>
                    <TableColumn text="POČET"
                               fx:id="colCount"
                               prefWidth="100"
                               sortable="false"/>
                </columns>
                <placeholder>
                    <VBox alignment="CENTER" spacing="10">
                        <FontIcon iconLiteral="fa-inbox" iconSize="48" styleClass="empty-icon"/>
                        <Label text="Žiadne kombinácie" styleClass="empty-label"/>
                    </VBox>
                </placeholder>
            </TableView>

            <!-- Remove button -->
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="removeButton"
                       text="Odstrániť vybranú"
                       styleClass="btn btn-danger"
                       onAction="#onRemoveCombination">
                    <graphic>
                        <FontIcon iconLiteral="fa-trash" iconSize="12"/>
                    </graphic>
                </Button>
            </HBox>
        </VBox>
    </VBox>

    <Separator styleClass="dialog-separator"/>

    <!-- Footer -->
    <HBox styleClass="dialog-footer" alignment="CENTER_RIGHT" spacing="12">
        <padding>
            <Insets top="16" right="24" bottom="16" left="24"/>
        </padding>

        <Button fx:id="closeButton"
               text="Zavrieť"
               styleClass="btn btn-secondary"
               onAction="#onClose"
               prefWidth="120">
            <graphic>
                <FontIcon iconLiteral="fa-check" iconSize="12"/>
            </graphic>
        </Button>
    </HBox>
</VBox>

