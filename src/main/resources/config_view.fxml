<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>


<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="uniza.fri.majba.dis1.ui.controller.ConfigController"
           styleClass="app-root">

    <VBox prefWidth="1200" prefHeight="760">

        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
            <padding>
                <Insets top="14" right="18" bottom="14" left="18"/>
            </padding>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button fx:id="backButton" styleClass="btn btn-secondary btn-toolbar" onAction="#onBack">
                    <graphic>
                        <FontIcon iconLiteral="fa-arrow-left" iconSize="14"/>
                    </graphic>
                </Button>
                <FontIcon iconLiteral="fa-cog" iconSize="20" styleClass="app-icon"/>
                <Label text="Konfigurácia simulácie" styleClass="app-title"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <ScrollPane fitToWidth="true" styleClass="config-scroll" VBox.vgrow="ALWAYS">
            <VBox styleClass="content" spacing="24">
                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>

                <Label text="Parametre simulácie" styleClass="page-title"/>


                <VBox styleClass="card" spacing="14">
                    <padding>
                        <Insets top="18" right="18" bottom="18" left="18"/>
                    </padding>
                    <GridPane hgap="16" vgap="12" styleClass="config-grid">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="40"/>
                            <ColumnConstraints percentWidth="60"/>
                        </columnConstraints>

                        <Label text="Seed generátora" styleClass="config-label"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="seedField" styleClass="toolbar-input"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Počet replikácií" styleClass="config-label"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="replicationsField" styleClass="toolbar-input"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Kolko % replikácií preskočiť" styleClass="config-label"
                               GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="skipPercentageField" styleClass="toolbar-input"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="Kolko % bočet reodov vykresliť" styleClass="config-label"
                               GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextField fx:id="renderPercentageField" styleClass="toolbar-input"
                                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                        <Label text="Čas začiatku simulácie (h)" styleClass="config-label"
                               GridPane.columnIndex="0" GridPane.rowIndex="4"/>

                        <Label text="Počet bodov na grafe" styleClass="config-label"
                               GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                        <Label fx:id="chartPointsLabel" text="—" styleClass="config-label"
                               GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                        <Spinner fx:id="simulationStartTimeSpinner"
                                 GridPane.columnIndex="1"
                                 GridPane.rowIndex="4"
                                 maxWidth="Infinity"/>
                    </GridPane>
                </VBox>

                <Label fx:id="statusLabel" styleClass="page-subtitle"/>

                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="Zrušiť" styleClass="btn btn-secondary btn-toolbar" onAction="#onBack">
                        <graphic>
                            <FontIcon iconLiteral="fa-times" iconSize="12"/>
                        </graphic>
                    </Button>
                    <Button text="Uložiť" styleClass="btn btn-nav btn-toolbar" onAction="#onSaveAndGoBack">
                        <graphic>
                            <FontIcon iconLiteral="fa-check" iconSize="12"/>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</StackPane>

